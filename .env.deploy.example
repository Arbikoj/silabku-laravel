APP_NAME=Silabku
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://labsd.web.id

# Port publish untuk service `web` (host:container).
# Jika port 80 di server sudah dipakai service lain, ganti ke port kosong (mis. 8081).
WEB_PORT=80

# Vite (tidak dipakai di server, hanya jika menjalankan profile `dev`)
VITE_PORT=5173
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL=https://labsd.web.id

# === PostgreSQL (Docker) ===
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=silabku
DB_USERNAME=silabku
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=labsd.web.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Jalankan migrate saat container start (AMAN untuk production).
APP_STARTUP_ARTISAN_COMMAND=migrate --force

# === Cloudflare Tunnel (labsd.web.id) ===
CLOUDFLARE_TUNNEL_TOKEN=

